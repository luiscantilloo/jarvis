# ─── J.A.R.V.I.S. Mk V Ultra — Configuración de Entorno ──────────────────────

# OPCIÓN 1: API de Gemini (Requiere internet)
# Obtén tu key en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_clave_gemini_aqui

# Modelo de Gemini a usar (por defecto: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# OPCIÓN 2: Ollama local (Sin internet, 100% offline)
# Instala Ollama: https://ollama.ai
# Luego ejecuta: ollama pull llama3
# JARVIS detectará Ollama automáticamente en localhost:11434
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# Puerto del servidor (por defecto: 3000)
# PORT=3000
